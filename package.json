{
  "name": "nexus-browser",
  "private": true,
  "version": "1.5.0",
  "main": "electron/main/browser_main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/victorpgdev/NexusWeb"
  },
  "description": "NEXUS: The High-Performance Secure Browser",
  "author": "Victor Hugo",
  "scripts": {
    "vite:dev": "vite",
    "electron:dev": "wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 NODE_ENV=development electron .",
    "dev": "concurrently \"npm run vite:dev\" \"npm run electron:dev\"",
    "build": "vite build && electron-builder build --win --publish never",
    "publish": "vite build && electron-builder build --win --publish always",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.nexus.browser",
    "productName": "Nexus Browser",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "publish": [
        {
          "provider": "github",
          "owner": "victorpgdev",
          "repo": "NexusWeb"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Nexus Browser"
    }
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.34.0",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "cross-fetch": "^4.1.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.4.10",
    "lucide-react": "^0.479.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.20.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.14.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.0",
    "wait-on": "^8.0.2"
  }
}
